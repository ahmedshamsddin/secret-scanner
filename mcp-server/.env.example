# URL of your running backend
SECRET_SCANNER_API_URL=http://localhost:4000

# Your Supabase user JWT token (get by logging in via the frontend)
SECRET_SCANNER_API_TOKEN=your-supabase-jwt-token

# Transport: "stdio" for local tools (Claude Desktop, Cursor) or "http" for remote
TRANSPORT=stdio

# Only needed if TRANSPORT=http
PORT=5000
